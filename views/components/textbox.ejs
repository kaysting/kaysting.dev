<%
    // Generate a random ID if one isn't provided
    const id = locals.id ?? `textbox-${utils.randomHex()}`;
    const symbol = locals.symbol ?? '';
    const symbolOutlined = locals.symbolOutlined ?? false;
    const label = locals.label ?? '';
    const type = locals.type ?? 'text';
    const placeholder = locals.placeholder ?? '';
    const value = locals.value ?? '';
    const name = locals.name ?? '';
    // Options when type is select (dropdown menu)
    const options = (locals.options ?? []).map(opt => ({
        label: opt.label ?? '',
        value: opt.value ?? opt.label ?? '',
        selected: opt.selected ?? false,
        disabled: opt.disabled ?? false
    }));
    // If a label is present, default to vertical layout
    const vertical = locals.vertical ?? !!label;
    const multiline = locals.multiline ?? false;
    const rows = locals.rows ?? 3;
    const expandable = locals.expandable ?? true;
    // Dynamic (variable height) is always true with vertical or multiline
    const dynamic = locals.dynamic ?? (vertical || multiline);
    // Default size to medium if using vertical layout
    // The default size is the same height so :shrug:
    const size = locals.size ?? (vertical ? 'medium' : null) ?? '';
    const width = locals.width ?? '';
    // Accept any extra input element attributes as key value pairs
    const attrs = (locals.attrs ?? {});
    const attrsStr = Object.entries(attrs)
        .map(([key, value]) => `${key}="${String(value).replace(/"/g, '&quot;')}"`)
        .join(' ');
    // Default validity to null
    // true makes the outline green, false makes it red
    const valid = locals.valid ?? null;
    const readonly = locals.readonly ?? false;
    const copyTextButton = locals.copyTextButton ?? false;
%>

<div
    class="textbox
        <%= size %>
        <%= dynamic ? 'dynamic' : '' %>
        <%= type == 'select' ? 'pointer' : '' %>
        <%= attrs.disabled ? 'disabled' : '' %>
        <%= valid === false ? 'danger' : valid === true ? 'success' : '' %>"
    style="width: <%= width ? `${width}px` : 'auto' %>"
>
    <% if (symbol) { %>
        <span class="symbol <%= symbolOutlined ? '' : 'filled' %>"><%= symbol %></span>
    <% } %>

    <% if (vertical) { %>
        <div class="vertical">
    <% } %>

            <% if (label) { %>
                <label for="<%= id %>"><%= label %></label>
            <% } %>

            <% if (multiline) { %>

                <textarea
                    name="<%= name %>"
                    id="<%= id %>"
                    placeholder="<%= placeholder %>"
                    rows="<%= rows %>"
                    data-expandable="<%= expandable %>"
                    <%= readonly ? 'disabled' : '' %>
                    <%- attrsStr %>
                ><%= value %></textarea>

            <% } else if (type == 'select') { %>

                <select
                    name="<%= name %>"
                    id="<%= id %>"
                    <%= readonly ? 'disabled' : '' %>
                >
                    <% for( const opt of options ) { %>
                        <option
                            value="<%= opt.value %>"
                            <%= opt.selected ? 'selected' : '' %>
                            <%= opt.disabled ? 'disabled' : '' %>
                        ><%= opt.label %></option>
                    <% } %>
                </select>

            <% } else { %>

                <input
                    type="<%= type %>"
                    id="<%= id %>"
                    name="<%= name %>"
                    placeholder="<%= placeholder %>"
                    value="<%= value %>"
                    <%= readonly ? 'disabled' : '' %>
                    <%- attrsStr %>
                />
                
            <% } %>

    <% if (vertical) { %>
        </div>
    <% } %>

    <% if (type == 'select') { %>
        <span class="symbol">keyboard_arrow_down</span>
    <% } %>

    <% if (type == 'password') { %>
        <button id="<%= id %>-btnTogglePassVisibility" class="btn small tertiary circle" title="Show password">
            <span class="symbol filled">visibility</span>
        </button>
        <script>
            document.querySelector('#<%= id %>-btnTogglePassVisibility').addEventListener('click', () => {
                const input = document.querySelector(`#<%= id %>`);
                const btn = document.querySelector(`#<%= id %>-btnTogglePassVisibility`);
                const symbol = btn.querySelector('.symbol');
                if (input.type == 'password') {
                    input.type = 'text';
                    btn.title = 'Hide password';
                    symbol.innerText = 'visibility_off';
                } else {
                    input.type = 'password';
                    btn.title = 'Show password';
                    symbol.innerText = 'visibility';
                }
            })
        </script>
    <% } %>

    <% if (copyTextButton) { %>
        <button id="<%= id %>-btnCopyText" class="btn small text circle" title="Copy text">
            <span class="symbol">content_copy</span>
        </button>
        <script>
            document.querySelector('#<%= id %>-btnCopyText').addEventListener('click', () => {
                copyText(document.querySelector('#<%= id %>').value);
            })
        </script>
    <% } %>
</div>